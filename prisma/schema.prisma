generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  PAID
  UNPAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  INSURANCE
  OTHER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttachmentCategory {
  LAB_RESULT
  XRAY
  MRI
  CT_SCAN
  PRESCRIPTION
  MEDICAL_REPORT
  OTHER
}

enum NotificationType {
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
  APPOINTMENT_CANCELLED
  APPOINTMENT_REMINDER
  PATIENT_CREATED
  INVOICE_CREATED
  INVOICE_PAID
  PRESCRIPTION_CREATED
  SYSTEM
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReminderType {
  TWENTY_FOUR_HOURS_BEFORE
  TWO_HOURS_BEFORE
  THIRTY_MINUTES_BEFORE
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum BookingSource {
  WEBSITE
  PHONE
  RECEPTION
  WHATSAPP
}

// ── Multi-Branch Support ─────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  code      String
  address   String?
  city      String?
  phone     String?
  email     String?
  managerId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  manager     User?         @relation("BranchManager", fields: [managerId], references: [id], onDelete: SetNull)

  patients      Patient[]
  appointments  Appointment[]
  invoices      Invoice[]
  payments      Payment[]
  visits        Visit[]
  prescriptions Prescription[]
  notifications Notification[]
  auditLogs     AuditLog[]
  bookings      Booking[]
  doctorSchedules DoctorSchedule[]
  userBranches  UserBranch[]
  doctorBranches DoctorBranch[]

  @@unique([clinicId, code])
  @@index([clinicId])
  @@map("branches")
}

model UserBranch {
  id       String @id @default(cuid())
  userId   String
  branchId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@map("user_branches")
}

model DoctorBranch {
  id       String @id @default(cuid())
  doctorId String
  branchId String

  doctor User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([doctorId, branchId])
  @@map("doctor_branches")
}

// ── Core Models ──────────────────────────────────────

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  password        String?
  role            Role          @default(RECEPTIONIST)
  allBranchAccess Boolean       @default(false) 

  appointmentDuration   Int     @default(30)
  maxDailyAppointments  Int     @default(20)

  clinicId        String
  clinic          Clinic        @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  ownedClinics    Clinic[]      @relation("ClinicOwner")
  managedBranches Branch[]      @relation("BranchManager")
  appointments    Appointment[]
  visits          Visit[]
  attachments     Attachment[]
  prescriptions   Prescription[]
  schedules       DoctorSchedule[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  payments        Payment[]
  notificationSettings NotificationSettings?
  doctorBookings  Booking[]     @relation("DoctorBookings")
  userBranches    UserBranch[]
  doctorBranches  DoctorBranch[]

  emailVerified   DateTime?
  image           String?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([email])
  @@map("users")
}

model Clinic {
  id           String              @id @default(cuid())
  name         String
  address      String?
  phone        String?
  ownerId      String?             // ← تم التعديل هنا: أصبح اختياري
  owner        User?               @relation("ClinicOwner", fields: [ownerId], references: [id], onDelete: Restrict) // ← تم التعديل هنا: أصبح اختياري
  users        User[]
  patients     Patient[]
  appointments Appointment[]
  invoices     Invoice[]
  payments     Payment[]
  visits       Visit[]
  prescriptions Prescription[]
  subscription Subscription?
  settings     ClinicSettings?
  workingHours ClinicWorkingHours[]
  notifications Notification[]
  bookings     Booking[]
  auditLogs    AuditLog[]
  branches     Branch[]

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([ownerId])
  @@index([phone])
  @@map("clinics")
}

model Patient {
  id          String            @id @default(cuid())
  fullName    String
  phone       String
  email       String?
  gender      Gender
  dateOfBirth DateTime
  address     String?
  clinicId    String
  branchId    String? 
  clinic      Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  branch      Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  invoices    Invoice[]
  visits      Visit[]
  attachments Attachment[]
  prescriptions Prescription[]
  bookings    Booking[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([clinicId])
  @@index([branchId]) 
  @@index([phone])
  @@index([email])
  @@map("patients")
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId  String
  doctor    User              @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  clinicId  String
  branchId  String? 
  clinic    Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  branch    Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  dateTime  DateTime
  status    AppointmentStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  reminders Reminder[]
  booking   Booking?

  @@index([patientId])
  @@index([doctorId])
  @@index([clinicId])
  @@index([branchId]) 
  @@index([dateTime])
  @@index([status])
  @@map("appointments")
}

// ── Invoice Items ────────────────────────────────────

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_items")
}

// ── Invoices (Phase 22E Enhanced) ────────────────────

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String?       @unique
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  clinicId      String
  branchId      String? 
  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  amount        Decimal       @db.Decimal(10, 2)
  tax           Decimal       @default(0) @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  dueDate       DateTime?
  notes         String?
  status        InvoiceStatus @default(UNPAID)
  items         InvoiceItem[]
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([patientId])
  @@index([clinicId])
  @@index([branchId]) 
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@map("invoices")
}

// ── Payments (Phase 22E) ─────────────────────────────

model Payment {
  id           String        @id @default(cuid())
  invoiceId    String
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod @default(CASH)
  reference    String?
  notes        String?
  recordedById String
  recordedBy   User          @relation(fields: [recordedById], references: [id], onDelete: Restrict)
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([invoiceId])
  @@index([clinicId])
  @@index([branchId])
  @@index([recordedById])
  @@index([method])
  @@index([createdAt])
  @@map("payments")
}

// ── SaaS Plans & Subscriptions ──────────────────────────

model Plan {
  id                   String   @id @default(cuid())
  name                 String   @unique
  slug                 String   @unique
  description          String?
  monthlyPrice         Float    @default(0)
  yearlyPrice          Float    @default(0)
  maxDoctors           Int      @default(1) 
  maxUsers             Int      @default(2) 
  maxPatients          Int      @default(500) 
  maxBranches          Int      @default(1) 
  onlineBookingEnabled Boolean  @default(false)
  analyticsEnabled     Boolean  @default(false)
  notificationsEnabled Boolean  @default(true)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  subscriptions        Subscription[]

  @@map("plans")
}

model Subscription {
  id          String             @id @default(cuid())
  clinicId    String             @unique
  clinic      Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  planId      String
  plan        Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status      SubscriptionStatus @default(TRIAL)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  trialEndsAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

// ── Auth Models ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id String @id @default(cuid())

  sessionToken String @unique

  userId String

  expires DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String

  token String @unique

  expires DateTime

  @@unique([identifier, token])
}

// ── Medical Records ──────────────────────────────────

model Visit {
  id        String   @id @default(cuid())
  clinicId  String
  branchId  String? 
  patientId String
  doctorId  String
  visitDate DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic         Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch         Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  patient        Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor         User                @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  complaints     VisitComplaint[]
  diagnoses      VisitDiagnosis[]
  treatmentPlans VisitTreatmentPlan[]
  prescription   Prescription?

  @@index([clinicId])
  @@index([branchId]) 
  @@index([patientId])
  @@index([doctorId])
  @@map("visits")
}

model VisitComplaint {
  id        String @id @default(cuid())
  visitId   String
  complaint String

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("visit_complaints")
}

model VisitDiagnosis {
  id        String @id @default(cuid())
  visitId   String
  diagnosis String

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("visit_diagnoses")
}

model VisitTreatmentPlan {
  id        String @id @default(cuid())
  visitId   String
  treatment String

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("visit_treatment_plans")
}

// ── Medical Dictionary (Smart Suggestions Layer) ─────

model ComplaintMaster {
  id        String   @id @default(cuid())
  name      String   @unique
  specialty String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("complaint_masters")
}

model DiagnosisMaster {
  id        String   @id @default(cuid())
  name      String   @unique
  specialty String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("diagnosis_masters")
}

// ── Treatment Templates ──────────────────────────────

model TreatmentTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String
  specialty String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@map("treatment_templates")
}

// ── Egyptian Drug Database ───────────────────────────

model DrugMaster {
  id          String   @id @default(cuid())
  name        String
  genericName String
  category    String?
  form        String?
  dosage      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, dosage])
  @@index([name])
  @@index([genericName])
  @@map("drug_masters")
}

// ── Patient Attachments ──────────────────────────────

model Attachment {
  id           String             @id @default(cuid())
  patientId    String
  uploadedById String
  fileName     String
  fileUrl      String
  fileType     String
  category     AttachmentCategory
  fileSize     Int
  createdAt    DateTime           @default(now())

  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy  User               @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([category])
  @@map("attachments")
}

// ── Electronic Prescriptions ─────────────────────────

model Prescription {
  id        String              @id @default(cuid())
  clinicId  String
  branchId  String? 
  patientId String
  doctorId  String
  visitId   String?             @unique
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  clinic    Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch    Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  patient   Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User                @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  visit     Visit?              @relation(fields: [visitId], references: [id], onDelete: SetNull)
  items     PrescriptionItem[]

  @@index([clinicId])
  @@index([branchId]) 
  @@index([patientId])
  @@index([doctorId])
  @@index([visitId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id              String       @id @default(cuid())
  prescriptionId  String
  medicationName  String
  dosage          String
  frequency       String
  duration        String
  instructions    String?

  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ── Clinic Branding, Settings & Configuration ────────

model ClinicSettings {
  id                          String   @id @default(cuid())
  clinicId                    String   @unique
  clinicName                  String
  logoUrl                     String?
  address                     String?
  phone                       String?
  email                       String?
  website                     String?
  taxNumber                   String?
  currency                    String   @default("EGP")
  timezone                    String   @default("Africa/Cairo")
  defaultAppointmentDuration  Int      @default(30)
  dateFormat                  String   @default("dd/MM/yyyy")
  timeFormat                  String   @default("24h")
  enableNotifications         Boolean  @default(true)
  enableOnlineBooking         Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  clinic                      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_settings")
}

model ClinicWorkingHours {
  id          String   @id @default(cuid())
  clinicId    String
  dayOfWeek   Int
  startTime   String   @default("09:00")
  endTime     String   @default("17:00")
  isClosed    Boolean  @default(false)

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, dayOfWeek])
  @@map("clinic_working_hours")
}

model DoctorSchedule {
  id          String   @id @default(cuid())
  doctorId    String
  branchId    String? 
  dayOfWeek   Int
  startTime   String   @default("09:00")
  endTime     String   @default("17:00")
  isAvailable Boolean  @default(true)

  doctor      User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([doctorId, branchId, dayOfWeek]) 
  @@map("doctor_schedules")
}

// ── Notifications & Reminders ────────────────────────

model Notification {
  id                 String           @id @default(cuid())
  clinicId           String
  branchId           String? 
  userId             String
  title              String
  message            String
  type               NotificationType @default(SYSTEM)
  priority           Priority         @default(MEDIUM)
  isRead             Boolean          @default(false)
  relatedEntityType  String?
  relatedEntityId    String?
  createdAt          DateTime         @default(now())
  readAt             DateTime?

  clinic             Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch             Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([branchId]) 
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Reminder {
  id            String         @id @default(cuid())
  appointmentId String
  reminderType  ReminderType
  scheduledFor  DateTime
  sentAt        DateTime?
  status        ReminderStatus @default(PENDING)
  createdAt     DateTime       @default(now())

  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([status, scheduledFor])
  @@map("reminders")
}

model NotificationSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  enableInApp           Boolean  @default(true)
  enableEmail           Boolean  @default(false)
  enableSMS             Boolean  @default(false)
  enableWhatsApp        Boolean  @default(false)
  appointmentReminders  Boolean  @default(true)
  invoiceNotifications  Boolean  @default(true)
  systemNotifications   Boolean  @default(true)

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

// ── Online Booking ───────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  appointmentId String       @unique
  patientId     String
  doctorId      String
  clinicId      String
  branchId      String? 
  status        BookingStatus @default(PENDING)
  source        BookingSource @default(WEBSITE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        User          @relation("DoctorBookings", fields: [doctorId], references: [id], onDelete: Cascade)
  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([branchId]) 
  @@index([doctorId])
  @@index([status])
  @@map("bookings")
}

// ── Audit Logs & Activity Tracking ───────────────────

model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String
  branchId   String? 
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
  @@index([branchId]) 
  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}